rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isFamilyUser() {
      return request.auth != null
        && (
          request.auth.uid in [
            "v5y5ycBQw8W1C7cjcLppOHBPOD93",
            "vbTLMWoYdwUEM6aI1vaUkDK8trV2"
          ]
          || request.auth.token.email in [
            "lolas8228@gmail.com",
            "k89150@gmail.com"
          ]
        );
    }

    function canAccessWorkspace(workspaceId) {
      return isSignedIn()
        && (
          (workspaceId == "family" && isFamilyUser())
          || workspaceId == request.auth.uid
        );
    }

    match /workspaces/{workspaceId}/orders/{orderId} {
      allow read, write: if canAccessWorkspace(workspaceId);
    }

    match /workspaces/{workspaceId}/costSheets/{sheetId} {
      allow read, write: if canAccessWorkspace(workspaceId);
    }

    match /workspaces/{workspaceId}/inventoryItems/{itemId} {
      allow read, write: if canAccessWorkspace(workspaceId);
    }

    // Legacy collections are kept read-only for the family accounts so the app
    // can migrate existing data into workspaces/family on first use.
    match /orders/{orderId} {
      allow read: if isFamilyUser();
      allow write: if false;
    }

    match /costSheets/{sheetId} {
      allow read: if isFamilyUser();
      allow write: if false;
    }

    match /inventoryItems/{itemId} {
      allow read: if isFamilyUser();
      allow write: if false;
    }
  }
}
